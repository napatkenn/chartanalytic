# Database: PostgreSQL (required on Vercel; use e.g. Vercel Postgres, Neon, or Supabase)
DATABASE_URL="postgresql://user:password@localhost:5432/chartanalytic"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
# On Vercel set AUTH_TRUST_HOST=true so login works on preview URLs
# AUTH_TRUST_HOST="true"

# Google OAuth (Sign in with Google). Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OTP (registration email verification).
# Set to your app URL (e.g. https://chartanalyticsai.com) to use built-in OTP with Gmail below.
# Set to "skip" to disable OTP (any code accepted on verify). Use only for local/testing.
OTP_SERVICE_URL="https://chartanalyticsai.com"
# Gmail for sending OTP (when OTP_SERVICE_URL points to this app). Use App Password: https://myaccount.google.com/apppasswords
GMAIL_OTP_USER=""
GMAIL_OTP_APP_PASSWORD=""
# Support form: inbox where support messages are sent (default: chartanalyticai@gmail.com)
# SUPPORT_EMAIL="chartanalyticai@gmail.com"

# OpenAI (for chart analysis)
OPENAI_API_KEY="sk-..."

# Optional: local uploads directory (default: ./uploads)
# UPLOAD_DIR="./uploads"

# Vercel Blob (recommended on Vercel): set automatically when you add Blob storage to the project.
# When set, uploads are stored in Blob instead of local disk so they persist across serverless invocations.
# BLOB_READ_WRITE_TOKEN=""

# Optional: base URL for serving uploads (e.g. CDN). If set, relative /api/uploads/... URLs are resolved with this base.
# STORAGE_BASE_URL="https://your-cdn.com"

# ---- BoomFi (crypto payments & subscriptions) ----
# Get API key from https://app.boomfi.xyz/dashboard (API settings)
BOOMFI_API_KEY=""
# Webhook signing public key (PEM) from Merchant Dashboard → Integration → Webhooks
BOOMFI_WEBHOOK_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# Optional: use test base URL
# BOOMFI_BASE_URL="https://test.boomfi.xyz"
# Option A: Existing pay link URLs from BoomFi dashboard (paste full URL for each tier)
BOOMFI_PAYLINK_STARTER=""
BOOMFI_PAYLINK_ACTIVE=""
BOOMFI_PAYLINK_ADVANCED=""
# Option B: Plan IDs if you create pay links via API instead
BOOMFI_PLAN_ID_STARTER=""
BOOMFI_PLAN_ID_ACTIVE=""
BOOMFI_PLAN_ID_ADVANCED=""
# Set to "true" to test subscriptions without BoomFi plans (activates plan locally when you click Subscribe)
# ENABLE_DEMO_SUBSCRIPTION="true"

# ---- Analyze image API (for social-agent / cron) ----
# Optional. When set, POST /api/analyze-image accepts Authorization: Bearer <ANALYZE_IMAGE_SECRET>
# and analyzes the uploaded chart image (no user auth, no credits). Used by social-agent to run analysis via app.
# Generate a random string, e.g. node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ANALYZE_IMAGE_SECRET=""

# ---- Social agent (TradingView capture + post to X) ----
# X (Twitter) API: https://developer.x.com → create project & app → Keys and tokens: API Key, API Secret, then generate Access Token + Access Token Secret for your account.
X_API_KEY=""
X_API_SECRET=""
X_ACCESS_TOKEN=""
X_ACCESS_TOKEN_SECRET=""
# Chart Analytic app for analysis (optional): captured image is sent to app. Otherwise uses OPENAI_API_KEY.
# CHART_ANALYTIC_URL="http://localhost:3000"
# ANALYZE_IMAGE_SECRET=""

# ---- Polymarket prediction bot (optional; use with --predict for btc/eth/sol/xrp) ----
# There is no separate "Polymarket API key". You use your wallet's PRIVATE KEY (0x...).
# Create or use an Ethereum wallet, fund it with USDC.e on Polygon (+ a little POL for gas).
# Export the private key and put it here (keep this secret; never commit .env).
POLYMARKET_PRIVATE_KEY="0x..."
# Optional: wallet address you see and fund on polymarket.com (e.g. 0xa917...). If set, CLOB uses this as funder instead of the relayer proxy.
# POLYMARKET_FUNDER_ADDRESS=
# Optional: use existing API credentials from Polymarket (Settings → API). If set, avoids "Could not create api key" — you must set all three.
# POLYMARKET_API_KEY="019c7fbf-4da4-7e12-8e9c-d13efb019c14"
# POLYMARKET_API_SECRET="..."
# POLYMARKET_PASSPHRASE="..."
# USD amount per Up/Down order; enforced minimum 5 (Polymarket CLOB min).
POLYMARKET_MAX_SIZE_USD=5
# Optional: Builder Program credentials for gasless USDC.e approval (no POL needed). Get from https://polymarket.com/settings?tab=builder
# If set, we run approve once via https://docs.polymarket.com/trading/gasless before placing orders.
# POLY_BUILDER_API_KEY=
# POLY_BUILDER_SECRET=
# POLY_BUILDER_PASSPHRASE=
# Optional: Polygon RPC for gasless relayer and redeem (wallet client). Default: https://polygon-mainnet.gateway.tatum.io
# For Tatum, set TATUM_API_KEY (or POLYGON_RPC_API_KEY) so requests are authenticated.
# POLYGON_RPC_URL=https://polygon-mainnet.gateway.tatum.io
# TATUM_API_KEY=
# Optional: HTTP proxy for Polymarket API only (geoblock). Format: http://user:pass@host:port
# PROXY_URL="http://uprsbhfa:aiic4y968f6o@142.111.67.146:5611"
# Only place when analysis confidence is at least this (0-100); default 65.
# POLYMARKET_MIN_CONFIDENCE=65
