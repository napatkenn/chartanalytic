# Database: PostgreSQL (required on Vercel; use e.g. Vercel Postgres, Neon, or Supabase)
DATABASE_URL="postgresql://user:password@localhost:5432/chartanalytic"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
# On Vercel set AUTH_TRUST_HOST=true so login works on preview URLs
# AUTH_TRUST_HOST="true"

# OTP (registration email verification). Base URL of otp-service (https://github.com/sauravhathi/otp-service).
# Public demo: https://otp-service-beta.vercel.app — or use your own deployment.
# Set to "skip" to disable OTP (any code accepted on verify). Use only for local/testing.
OTP_SERVICE_URL="https://otp-service-beta.vercel.app"

# OpenAI (for chart analysis)
OPENAI_API_KEY="sk-..."

# Optional: local uploads directory (default: ./uploads)
# UPLOAD_DIR="./uploads"

# Vercel Blob (recommended on Vercel): set automatically when you add Blob storage to the project.
# When set, uploads are stored in Blob instead of local disk so they persist across serverless invocations.
# BLOB_READ_WRITE_TOKEN=""

# Optional: base URL for serving uploads (e.g. CDN). If set, relative /api/uploads/... URLs are resolved with this base.
# STORAGE_BASE_URL="https://your-cdn.com"

# ---- BoomFi (crypto payments & subscriptions) ----
# Get API key from https://app.boomfi.xyz/dashboard (API settings)
BOOMFI_API_KEY=""
# Webhook signing public key (PEM) from Merchant Dashboard → Integration → Webhooks
BOOMFI_WEBHOOK_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# Optional: use test base URL
# BOOMFI_BASE_URL="https://test.boomfi.xyz"
# Option A: Existing pay link URLs from BoomFi dashboard (paste full URL for each tier)
BOOMFI_PAYLINK_STARTER=""
BOOMFI_PAYLINK_ACTIVE=""
BOOMFI_PAYLINK_ADVANCED=""
# Option B: Plan IDs if you create pay links via API instead
BOOMFI_PLAN_ID_STARTER=""
BOOMFI_PLAN_ID_ACTIVE=""
BOOMFI_PLAN_ID_ADVANCED=""
# Set to "true" to test subscriptions without BoomFi plans (activates plan locally when you click Subscribe)
# ENABLE_DEMO_SUBSCRIPTION="true"

# ---- Analyze image API (for social-agent / cron) ----
# Optional. When set, POST /api/analyze-image accepts Authorization: Bearer <ANALYZE_IMAGE_SECRET>
# and analyzes the uploaded chart image (no user auth, no credits). Used by social-agent to run analysis via app.
# Generate a random string, e.g. node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ANALYZE_IMAGE_SECRET=""

# ---- Social agent (TradingView capture + post to X) ----
# X (Twitter) API: https://developer.x.com → create project & app → Keys and tokens: API Key, API Secret, then generate Access Token + Access Token Secret for your account.
X_API_KEY=""
X_API_SECRET=""
X_ACCESS_TOKEN=""
X_ACCESS_TOKEN_SECRET=""
# Chart Analytic app for analysis (optional): captured image is sent to app. Otherwise uses OPENAI_API_KEY.
# CHART_ANALYTIC_URL="http://localhost:3000"
# ANALYZE_IMAGE_SECRET=""
